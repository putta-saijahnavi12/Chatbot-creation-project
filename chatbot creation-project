      "cell_type": "code",
      "source": [
        "from transformers import pipeline\n",
        "import gradio as gr\n",
        "\n",
        "pipe = pipeline(\n",
        "    \"text-generation\",\n",
        "    model=\"TinyLlama/TinyLlama-1.1B-Chat-v1.0\",\n",
        "    device_map=\"auto\"\n",
        ")\n",
        "\n",
        "def chat(message):\n",
        "    prompt = f\"<|user|>\\n{message}\\n<|assistant|>\\n\"\n",
        "\n",
        "    output = pipe(\n",
        "        prompt,\n",
        "        max_new_tokens=200,\n",
        "        do_sample=True,\n",
        "        temperature=0.7\n",
        "    )\n",
        "\n",
        "    answer = output[0][\"generated_text\"].split(\"<|assistant|>\")[-1].strip()\n",
        "    return answer\n",
        "\n",
        "gr.Interface(\n",
        "    fn=chat,\n",
        "    inputs=gr.Textbox(lines=2, placeholder=\"Ask anything...\"),\n",
        "    outputs=\"text\",\n",
        "    title=\"AI Chatbot (No API Key)\"\n",
        ").launch()\n"
      ],
